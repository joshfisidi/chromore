{
    "manifest_version": 3,
    "name": "Chromore — Chrome Usage Analytics",
    "version": "0.1.0",
    "description": "Tracks time spent in Chrome, open tabs, and top sites (local only).",
    "permissions": [
      "tabs",
      "storage",
      "alarms",
      "idle",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_title": "Chromore Analytics"
    },
    "icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
  